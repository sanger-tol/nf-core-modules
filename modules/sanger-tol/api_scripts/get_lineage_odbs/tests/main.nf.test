nextflow_process {

    name "Test Process API_SCRIPTS_GET_LINEAGE_ODBS"
    script "../main.nf"
    process "API_SCRIPTS_GET_LINEAGE_ODBS"
    tag "modules"
    tag "modules_sangertol"
    tag "api_scripts"
    tag "api_scripts/get_lineage_odbs"

    setup {
        // Download mapping files once for all tests
        def mapping_dir = new File("${launchDir}/mapping_files/")
        def raw_mapping_dir = new File("${launchDir}/raw_mapping_files/")
        mapping_dir.mkdirs()
        raw_mapping_dir.mkdirs()

        def all_mapping_files = [
            "archaea_odb10.2019-12-16", "bacteria_odb10.2019-12-16", "eukaryota_odb10.2019-12-16",
            "archaea_odb12.2024-11-15", "bacteria_odb12.2024-11-15", "eukaryota_odb12.2025-01-15",
        ]

        all_mapping_files.each { file_spec ->
            curlAndExtract("https://busco-data.s3.amazonaws.com/placement_files/mapping_taxids-busco_dataset_name.${file_spec}.txt.tar.gz", "${launchDir}/raw_mapping_files")
        }

        // Concatenate by version
        ['odb10', 'odb12'].each { version ->
            def version_files = all_mapping_files.findAll { it.contains(version) }
            if (version_files) {
                def firstDate = version_files[0].split('\\.')[1]
                def cmd = ['bash', '-c', "cat ${launchDir}/raw_mapping_files/*${version}* > ${launchDir}/mapping_files/${version}_mapping_file.${firstDate}.txt"]
                def proc = cmd.execute()
                proc.waitFor()
                if (proc.exitValue() != 0) {
                    throw new RuntimeException("Error - failed to cat ${version}_mapping_file: ${proc.err.text}")
                }
            }
        }
    }

    test( "homo_sapiens - fasta - basal and mammalia odb10" ) {
        config "./basal_and_mammalia.config"
        setup {
            def odb_list = [
                "bacteria_odb10", "archaea_odb10", "eukaryota_odb10", "mammalia_odb10",
                ]
            for (i in odb_list) {
                def fake_file = new File("${launchDir}/fake_odb/lineages/${i}/")
                fake_file.mkdirs()
            }
        }

        when {
            params {
                fake_odb_path   = "${launchDir}/fake_odb"
                mapping_dir     = "${launchDir}/mapping_files"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id:'GCA_000001405.15' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/homo_sapiens/scramble/test.fa', checkIfExists: true),
                ])
                input[1] = file(params.fake_odb_path, checkIfExists: true)
                input[2] = file(params.mapping_dir, checkIfExists: true, type: 'dir')
                input[3] = 9606
                input[4] = "mammalia"
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }

    test( "homo_sapiens - fasta - 10/12 ancestral ODBs" ) {
        config "./all_ancestral_odb.config"
        setup {
            def odb_list = [
                'tetrapoda_odb10', 'metazoa_odb10', 'mammalia_odb10', 'vertebrata_odb10', 'primates_odb10',
                'eukaryota_odb10', 'euarchontoglires_odb10', 'eutheria_odb10', 'eukaryota_odb12',
                'euarchontoglires_odb12', 'tetrapoda_odb12', 'metazoa_odb12', 'mammalia_odb12',
                'vertebrata_odb12', 'eutheria_odb12', 'primates_odb12'
                ]

            for (i in odb_list) {
                def fake_file = new File("${launchDir}/fake_odb/lineages/${i}/")
                fake_file.mkdirs()
            }
        }

        when {
            params {
                fake_odb_path   = "${launchDir}/fake_odb"
                mapping_dir     = "${launchDir}/mapping_files"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id:'GCA_000001405.15' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/homo_sapiens/scramble/test.fa', checkIfExists: true),
                ])
                input[1] = file(params.fake_odb_path, checkIfExists: true)
                input[2] = file(params.mapping_dir, checkIfExists: true, type: 'dir')
                input[3] = 9606
                input[4] = []
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }

    test( "homo_sapiens - fasta - stub" ) {
        options "-stub"
        config "./stub.config"

        setup {
            def fake_file = new File("${launchDir}/fake_odb/lineages/mamalian_odb10/")
            fake_file.mkdirs()
        }

        when {
            params {
                fake_odb_path   = "${launchDir}/fake_odb"
                mapping_dir     = "${launchDir}/mapping_files"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id:'GCA_000001405.15' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/homo_sapiens/scramble/test.fa', checkIfExists: true),
                ])
                input[1] = file(params.fake_odb_path, checkIfExists: true)
                input[2] = file(params.mapping_dir, checkIfExists: true, type: 'dir')
                input[3] = 9606
                input[4] = []
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }
}
