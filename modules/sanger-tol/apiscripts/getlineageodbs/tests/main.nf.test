nextflow_process {

    name "Test Process APISCRIPTS_GETLINEAGEODBS"
    script "../main.nf"
    process "APISCRIPTS_GETLINEAGEODBS"
    tag "modules"
    tag "modules_sangertol"
    tag "apiscripts"
    tag "apiscripts/getlineageodbs"

    setup {
        // Download mapping files once for all tests
        def mapping_dir = new File("${launchDir}/mapping_files/")
        mapping_dir.mkdirs()

        ['odb10', 'odb12'].each { version ->
            def cmd = ['bash', '-c', "cp ${projectDir}/modules/sanger-tol/apiscripts/getlineageodbs/resources/busco_mapping_files/${version}_mapping.txt ${launchDir}/mapping_files/"]
            def proc = cmd.execute()
            proc.waitFor()
            if (proc.exitValue() != 0) {
                throw new RuntimeException("Error - failed to copy ${version}_mapping.txt: ${proc.err.text}")
            }
        }
    }

    test( "homo_sapiens - fasta - basal and mammalia odb10" ) {
        config "./basal_and_mammalia.config"

        setup {
            def odb_list = [
                "bacteria_odb10", "archaea_odb10", "eukaryota_odb10", "mammalia_odb10",
                ]
            for (i in odb_list) {
                def fake_file = new File("${launchDir}/fake_odb/lineages/${i}/")
                fake_file.mkdirs()
            }
        }

        when {
            params {
                fake_odb_path   = "${launchDir}/fake_odb"
                mapping_dir     = "${launchDir}/mapping_files"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id:'GCA_000001405.15' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/homo_sapiens/scramble/test.fa', checkIfExists: true),
                ])
                input[1] = file(params.fake_odb_path, checkIfExists: true)
                input[2] = file(params.mapping_dir, checkIfExists: true, type: 'dir')
                input[3] = 9606
                input[4] = "mammalia"
                """
            }
        }

        then {
            def csv_object = path(process.out.csv[0][1]).csv(header: false)
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out,
                    csv_object.rows,
                ).match() }
            )
        }
    }

    test( "homo_sapiens - fasta - 10/12 ancestral ODBs" ) {
        config "./all_ancestral_odb.config"
        setup {
            def odb_list = [
                'tetrapoda_odb10', 'metazoa_odb10', 'mammalia_odb10', 'vertebrata_odb10', 'primates_odb10',
                'eukaryota_odb10', 'euarchontoglires_odb10', 'eutheria_odb10', 'eukaryota_odb12',
                'euarchontoglires_odb12', 'tetrapoda_odb12', 'metazoa_odb12', 'mammalia_odb12',
                'vertebrata_odb12', 'eutheria_odb12', 'primates_odb12'
                ]

            for (i in odb_list) {
                def fake_file = new File("${launchDir}/fake_odb/lineages/${i}/")
                fake_file.mkdirs()
            }
        }

        when {
            params {
                fake_odb_path   = "${launchDir}/fake_odb"
                mapping_dir     = "${launchDir}/mapping_files"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id:'GCA_000001405.15' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/homo_sapiens/scramble/test.fa', checkIfExists: true),
                ])
                input[1] = file(params.fake_odb_path, checkIfExists: true)
                input[2] = file(params.mapping_dir, checkIfExists: true, type: 'dir')
                input[3] = 9606
                input[4] = []
                """
            }
        }

        then {
            def csv_object = path(process.out.csv[0][1]).csv(header: false)
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out,
                    csv_object.rows,
                ).match() }
            )
        }
    }

    test( "homo_sapiens - fasta - stub" ) {
        options "-stub"
        config "./stub.config"

        setup {
            def fake_file = new File("${launchDir}/fake_odb/lineages/mamalian_odb10/")
            fake_file.mkdirs()
        }

        when {
            params {
                fake_odb_path   = "${launchDir}/fake_odb"
                mapping_dir     = "${launchDir}/mapping_files"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id:'GCA_000001405.15' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/homo_sapiens/scramble/test.fa', checkIfExists: true),
                ])
                input[1] = file(params.fake_odb_path, checkIfExists: true)
                input[2] = file(params.mapping_dir, checkIfExists: true, type: 'dir')
                input[3] = 9606
                input[4] = []
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }
}
