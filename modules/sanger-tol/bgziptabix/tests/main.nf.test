nextflow_process {

    name "Test Process BGZIPTABIX"
    script "../main.nf"
    process "BGZIPTABIX"

    tag "modules"
    tag "modules_sangertol"
    tag "bgziptabix"

    config "./nextflow.config"

    test("bed with short sequences") {
        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'Cantharis_rufa/analysis/icCanRufa1/read_mapping/pacbio/GCA_947369205.1.unmasked.pacbio.icCanRufa1_0_3.bed', checkIfExists: true),
                ])
                input[1] = ["", "", "", ""]
                input[2] = [true, true, 60000]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("bed with short sequences, tbi not wanted") {
        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'Cantharis_rufa/analysis/icCanRufa1/read_mapping/pacbio/GCA_947369205.1.unmasked.pacbio.icCanRufa1_0_3.bed', checkIfExists: true),
                ])
                input[1] = ["", "", "", ""]
                input[2] = [false, true, 60000]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("bed with short sequences, csi not wanted") {
        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'Cantharis_rufa/analysis/icCanRufa1/read_mapping/pacbio/GCA_947369205.1.unmasked.pacbio.icCanRufa1_0_3.bed', checkIfExists: true),
                ])
                input[1] = ["", "", "", ""]
                input[2] = [true, false, 60000]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("bed with long sequences (no tbi index possible)") {
        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'Cantharis_rufa/analysis/icCanRufa1/read_mapping/pacbio/GCA_947369205.1.unmasked.pacbio.icCanRufa1_0_3.bed', checkIfExists: true),
                ])
                input[1] = ["", "", "", ""]
                input[2] = [true, true, 2**30]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("bed with extra long sequences (no index possible at all)") {

        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'Cantharis_rufa/analysis/icCanRufa1/read_mapping/pacbio/GCA_947369205.1.unmasked.pacbio.icCanRufa1_0_3.bed', checkIfExists: true),
                ])
                input[1] = ["", "", "", ""]
                input[2] = [true, true, 2**34]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("tsv to bed") {
        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test' ], // meta map
                    file(params.nfcore_modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.annotated_intervals.tsv', checkIfExists: true),
                ])
                input[1] = ["1-3", 3, "", "bed"]
                input[2] = [true, true, 60000]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("unsorted tsv to bed") {
        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test' ], // meta map
                    file(params.nfcore_modules_testdata_base_path + 'genomics/mus_musculus/rnaseq_expression/Mus_musculus.anno.tsv', checkIfExists: true),
                ])
                input[1] = ["2-7,11,13", 1, "-k1,1 -k2,2n", "bed"]
                input[2] = [true, true, 60000]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("stub") {
        options "-stub"

        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'Cantharis_rufa/analysis/icCanRufa1/read_mapping/pacbio/GCA_947369205.1.unmasked.pacbio.icCanRufa1_0_3.bed', checkIfExists: true),
                ])
                input[1] = ["", "", "", ""]
                input[2] = [true, true, 60000]
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
