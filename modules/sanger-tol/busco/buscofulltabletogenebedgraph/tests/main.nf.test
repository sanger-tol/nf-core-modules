nextflow_process {

    name "Test Process BUSCOFULLTABLETOGENEBEDGRAPH"
    script "../main.nf"
    process "BUSCOFULLTABLETOGENEBEDGRAPH"

    tag "modules"
    tag "modules_sangertol"
    tag "busco"
    tag "busco/buscofulltabletogenebedgraph"

    config "./nextflow.config"

    test("bacteria full_table") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'Undibacterium_unclassified/analysis/full_table.tsv', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("bacteria full_table - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'Undibacterium_unclassified/analysis/full_table.tsv', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
