nextflow_process {

    name "Test Process NCBIDATASETS_GET_ODB"
    script "../main.nf"
    process "NCBIDATASETS_GET_ODB"
    tag "modules"
    tag "modules_sangertol"
    tag "ncbidatasets"
    tag "ncbidatasets/get_odb"
    tag "ncbidatasets/summarise_genome"

    config "./nextflow.config"

    setup {

        run("NCBIDATASETS_SUMMARISE_GENOME") {
            script "../../summarise_genome/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [ id:'GCA_000001405.15' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/homo_sapiens/scramble/test.fa', checkIfExists: true),
                ])
                """
            }
        }
    }

    test( "homo_sapiens - fasta - specific ODB" ) {
        setup {
            def fake_file = new File("${launchDir}/fake_path/lineages/mamalian_odb10/")
            fake_file.mkdirs()
        }

        when {
            process {
                """
                input[0] = NCBIDATASETS_SUMMARISE_GENOME.out.summary
                input[1] = "${launchDir}/fake_path/"
                input[2] = "odb10"
                input[3] = "specified"
                input[4] = "mamalian"
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }

    test( "homo_sapiens - fasta - all ancestral ODBs" ) {
        setup {

            def odb_list = [ "bacteria_odb10", "archaea_odb10", "eukaryota_odb10", "euarchontoglires_odb10", "eutheria_odb10" ]

            for (i in odb_list) {
                def fake_file = new File("${launchDir}/fake_path/lineages/${i}/")
                fake_file.mkdirs()
            }
        }

        when {
            process {
                """
                input[0] = NCBIDATASETS_SUMMARISE_GENOME.out.summary
                input[1] = "${launchDir}/fake_path/"
                input[2] = "odb10"
                input[3] = "ancestral_and_basal"
                input[4] = []
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }

    test( "homo_sapiens - fasta - stub" ) {
        options "-stub"

        setup {
            def fake_file = new File("${launchDir}/fake_path/lineages/mamalian_odb10/")
            fake_file.mkdirs()
        }

        when {
            process {
                """
                input[0] = NCBIDATASETS_SUMMARISE_GENOME.out.summary
                input[1] = "${launchDir}/fake_path/"
                input[2] = "odb10"
                input[3] = []
                input[4] = []
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }
}
