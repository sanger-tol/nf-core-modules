nextflow_process {

    name "Test Process NCBIDATASETS_SUMMARISE_GENOME"
    script "../main.nf"
    process "NCBIDATASETS_SUMMARISE_GENOME"
    tag "modules"
    tag "modules_sangertol"
    tag "ncbidatasets"
    tag "ncbidatasets/summarise_genome"

    config "./nextflow.config"

    test( "homo_sapiens - fasta" ) {
        when {
            process {
                """
                input[0] = [
                    [ id:'GCA_000001405.15' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/homo_sapiens/scramble/test.fa', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }

    test( "homo_sapiens - fasta - stub" ) {
        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'GCA_000001405.15' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/homo_sapiens/scramble/test.fa', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }
}
