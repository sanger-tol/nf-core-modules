nextflow_process {

    name "Test Process FINDTELOMERE"
    script "../main.nf"
    process "FINDTELOMERE"

    tag "modules"
    tag "modules_sangertol"
    tag "telomere"
    tag "telomere/findtelomere"

    test("GCA_963859965.1 - fasta") {

        when {
            process {
                """
                input[0] = [
                    [ id: "Cloeon_Dipeterum" ],
                    file(params.modules_testdata_base_path + 'Cloeon_dipterum/assembly/release/ieCloDipt1.1/insdc/GCA_949628265.1.fasta.gz', checkIfExists: true),
                    "CCTAA"
                ]
                input[1] = false
                """
            }
        }

        then {
            assert workflow.success
            assertAll(
                /*
                 * Strand BED glob outputs can be real zero-byte files when there are no motif hits;
                 * nf-test rejects snapshot md5 for empty files — omit telomere_bed_fwd/rev.
                 */
                { assert snapshot(process.out.telomere, process.out.windows, process.out.versions_java, process.out.versions_find_telomere).match() }
            )
        }
    }

    test("GCA_963859965.1 - fasta - split") {

        when {
            process {
                """
                input[0] = [
                    [ id: "Cloeon_Dipeterum" ],
                    file(params.modules_testdata_base_path + 'Cloeon_dipterum/assembly/release/ieCloDipt1.1/insdc/GCA_949628265.1.fasta.gz', checkIfExists: true),
                    "CCTAA"
                ]
                input[1] = true
                """
            }
        }

        then {
            assert workflow.success
            assertAll(
                { assert snapshot(process.out.telomere, process.out.windows_fwd, process.out.windows_rev, process.out.versions_java, process.out.versions_find_telomere).match() }
            )
        }
    }

    test("GCA_963859965.1 - fasta - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: "Cloeon_Dipeterum" ],
                    file(params.modules_testdata_base_path + 'Cloeon_dipterum/assembly/release/ieCloDipt1.1/insdc/GCA_949628265.1.fasta.gz', checkIfExists: true),
                    "CCTAA"
                ]
                input[1] = false
                """
            }
        }

        then {
            assert workflow.success
            assertAll(
                { assert snapshot(process.out.telomere, process.out.windows, process.out.versions_java, process.out.versions_find_telomere).match() }
            )
        }
    }
}
