nextflow_process {

    name "Test Process TELOMERE_FINDTELOMERE"
    script "../main.nf"
    process "TELOMERE_FINDTELOMERE"

    tag "modules"
    tag "modules_sangertol"
    tag "telomere"
    tag "telomere/findtelomere"

    config "./nextflow.config"

    test("GCA_963859965.1 - fasta") {

        when {
            params {
                    find_telomere_args      = ""
                    java_args               = "99.9 0.01"
            }
            process {
                """
                input[0] = [
                    [ id: "Cloeon_Dipeterum" ],
                    file(params.modules_testdata_base_path + 'Cloeon_dipterum/assembly/release/ieCloDipt1.1/insdc/GCA_949628265.1.fasta.gz', checkIfExists: true),
                    "CCTAA"
                ]
                input[1] = false
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("GCA_963859965.1 - fasta - split") {

        when {
            params {
                    find_telomere_args      = ""
                    java_args               = "99.9 0.01"
            }
            process {
                """
                input[0] = [
                    [ id: "Cloeon_Dipeterum" ],
                    file(params.modules_testdata_base_path + 'Cloeon_dipterum/assembly/release/ieCloDipt1.1/insdc/GCA_949628265.1.fasta.gz', checkIfExists: true),
                    "CCTAA"
                ]
                input[1] = true
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("GCA_963859965.1 - fasta - stub") {

        options "-stub"

        when {
            params {
                    find_telomere_args      = ""
                    java_args               = "99.9 0.01"
            }
            process {
                """
                input[0] = [
                    [ id: "Cloeon_Dipeterum" ],
                    file(params.modules_testdata_base_path + 'Cloeon_dipterum/assembly/release/ieCloDipt1.1/insdc/GCA_949628265.1.fasta.gz', checkIfExists: true),
                    "CCTAA"
                ]
                input[1] = false
                """
            }
        }

        then {
            assert process.success
            assertAll(
                /* Stub outputs are non-empty placeholders; full process.out matches nf-core snapshot coverage. */
                { assert snapshot(process.out).match() }
            )
        }
    }
}
