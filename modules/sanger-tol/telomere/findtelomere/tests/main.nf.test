nextflow_process {

    name "Test Process FINDTELOMERE"
    script "../main.nf"
    process "FINDTELOMERE"

    tag "modules"
    tag "modules_sangertol"
    tag "telomere"
    tag "telomere/findtelomere"

    test("GCA_963859965.1 - fasta") {

        when {
            process {
                """
                input[0] = [
                    [ id: "Cloeon_Dipeterum" ],
                    file(params.modules_testdata_base_path + 'Cloeon_dipterum/assembly/release/ieCloDipt1.1/insdc/GCA_949628265.1.fasta.gz', checkIfExists: true),
                    "CCTAA"
                ]
                input[1] = false
                """
            }
        }

        then {
            assert process.success
            assertAll(
                /*
                 * Optional BED / windows files can be zero-byte; nf-test rejects snapshot md5 for empty
                 * files on non-stub tests. `process.out.*` here are materialized lists — combine with `+`,
                 * not Channel.mix().
                 */
                { assert snapshot([
                    telomere: process.out.telomere,
                    versions_java: process.out.versions_java,
                    versions_find_telomere: process.out.versions_find_telomere,
                    versions: (process.out.versions_java as List) + (process.out.versions_find_telomere as List),
                ]).match() }
            )
        }
    }

    test("GCA_963859965.1 - fasta - split") {

        when {
            process {
                """
                input[0] = [
                    [ id: "Cloeon_Dipeterum" ],
                    file(params.modules_testdata_base_path + 'Cloeon_dipterum/assembly/release/ieCloDipt1.1/insdc/GCA_949628265.1.fasta.gz', checkIfExists: true),
                    "CCTAA"
                ]
                input[1] = true
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot([
                    telomere: process.out.telomere,
                    versions_java: process.out.versions_java,
                    versions_find_telomere: process.out.versions_find_telomere,
                    versions: (process.out.versions_java as List) + (process.out.versions_find_telomere as List),
                ]).match() }
            )
        }
    }

    test("GCA_963859965.1 - fasta - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: "Cloeon_Dipeterum" ],
                    file(params.modules_testdata_base_path + 'Cloeon_dipterum/assembly/release/ieCloDipt1.1/insdc/GCA_949628265.1.fasta.gz', checkIfExists: true),
                    "CCTAA"
                ]
                input[1] = false
                """
            }
        }

        then {
            assert process.success
            assertAll(
                /* Stub outputs are non-empty placeholders; full process.out matches nf-core snapshot coverage. */
                { assert snapshot(process.out).match() }
            )
        }
    }
}
