nextflow_workflow {

    name "Test Subworkflow BUSCO_GENE"
    script "../main.nf"
    workflow "BUSCO_GENE"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_sangertol"
    tag "subworkflows/busco_gene"
    tag "subworkflows/../../modules/nf-core/busco/busco"
    tag "busco/buscofulltabletogenebedgraph"
    tag "htslib/bgziptabix"
    tag "subworkflows/../../modules/nf-core/htslib/bgziptabix"

    setup {
        nfcoreInitialise("${launchDir}/library/")
        nfcoreInstall(
            "${launchDir}/library/",
            [
                "busco/busco",
                "htslib/bgziptabix",
            ]
        )
        nfcoreLink("${launchDir}/library/", "${baseDir}/modules/")
    }

    test("bacteroides_fragilis genome fasta.gz — bacteria_odb10") {

        when {
            workflow {
                """
                input[0] = channel.of([
                    [ id:'test' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/prokaryotes/bacteroides_fragilis/genome/genome.fna.gz', checkIfExists: true),
                ])
                input[1] = channel.of([[ id:'test' ], 'bacteria_odb10'])
                input[2] = params.busco_lineages_path ? file(params.busco_lineages_path) : []
                input[3] = false
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert path(workflow.out.complete_bedgraph.get(0).get(1)).readLines().findAll { it.trim() }.size() > 0 },
                { assert snapshot(
                    workflow.out.complete_bedgraph,
                    workflow.out.duplicated_bedgraph,
                    workflow.out.fragmented_bedgraph,
                    workflow.out.batch_summary
                ).match() }
            )
        }

        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }

    test("bacteroides_fragilis genome fasta.gz — bacteria_odb10 — zip bedgraph") {

        when {
            params {
                bgzip_args = '--csi'
            }
            workflow {
                """
                input[0] = channel.of([
                    [ id:'test' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/prokaryotes/bacteroides_fragilis/genome/genome.fna.gz', checkIfExists: true),
                ])
                input[1] = channel.of([[ id:'test' ], 'bacteria_odb10'])
                input[2] = params.busco_lineages_path ? file(params.busco_lineages_path) : []
                input[3] = true
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.complete_bedgraph,
                    workflow.out.duplicated_bedgraph,
                    workflow.out.fragmented_bedgraph,
                    workflow.out.gz_index
                ).match() }
            )
        }

        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }

}
