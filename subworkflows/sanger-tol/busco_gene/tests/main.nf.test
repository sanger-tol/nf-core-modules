nextflow_workflow {

    name "Test Subworkflow BUSCO_GENE"
    script "../main.nf"
    workflow "BUSCO_GENE"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_sangertol"
    tag "subworkflows/busco_gene"
    tag "subworkflows/../../modules/nf-core/busco/busco"
    tag "busco/fulltabletogenebedgraph"

    setup {
        nfcoreInitialise("${launchDir}/library/")
        nfcoreInstall(
            "${launchDir}/library/",
            [
                "busco/busco",
            ]
        )
        nfcoreLink("${launchDir}/library/", "${baseDir}/modules/")
    }

    test("bacteroides_fragilis genome fasta.gz — bacteria_odb10") {

        when {
            workflow {
                """
                input[0] = channel.of([
                    [ id:'test' ],
                    file(params.nfcore_modules_testdata_base_path + 'genomics/prokaryotes/bacteroides_fragilis/genome/genome.fna.gz', checkIfExists: true),
                ])
                input[1] = channel.of([[ id:'test' ], 'bacteria_odb10'])
                input[2] = []
                """
            }
        }

       then {
            assert workflow.success
            assertAll(
                { assert snapshot(workflow.out.bigwig, workflow.out.bedgraph).match() }
            )
        }

        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }

}
