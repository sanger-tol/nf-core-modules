process {
    withName: 'BUSCO_BUSCO' {
        // When a local lineages cache is available (params.busco_lineages_path set via
        // the BUSCO_LINEAGES_PATH env var in CI), use --offline to skip the mandatory
        // online version-check in BUSCO v6, which fails when the data servers are
        // temporarily unreachable. Fall back to online download otherwise.
        ext.args = '--tar --download_base_url https://busco-data.s3.amazonaws.com/v5/data'
    }

    withName: HTSLIB_BGZIPTABIX {
        ext.prefix = { infile.baseName }
        ext.args2 = { "${params.bgzip_args}" }
    }
}
