    test("meles meles - multiple read groups - minimap2") {

        when {
            params {
                samtools_cat_args     = ""
                samtools_fastq_args   = "-F0xB00 -nt"
                minimap2_args         = "-ax sr"
                samtools_fixmate_args = "-mpu"
                samtools_view_args    = "-q 0 -F 0x904"
                samtools_sort_args    = "--write-index -l1"
                samtools_markdup_args = "--write-index"

            }

            workflow {
                """
                input[0] = Channel.of(
                    [
                        [ id:'test' ], // meta map
                        file( params.modules_testdata_base_path + 'Biemna_sp_UH_2024/assembly/release/GCA_965654295.1/insdc/GCA_965654295.1.fa.gz', checkIfExists: true)
                    ]
                )
                input[1] = Channel.of(
                    [
                        [ id:'test' ],
                        file( params.modules_testdata_base_path + 'Biemna_sp_UH_2024/genomic_data/odBieUhxx1/hic-arima2/49103_5-6_5.subset.cram', checkIfExists: true)
                    ]
                )
                input[2] = "minimap2"
                input[3] = 1
                """
            }
        }

        then {
            // Fasta file for cram verification with nft-bam. Can't use params
            def fasta_base = 'https://tolit.cog.sanger.ac.uk/test-data/'
            def fasta = fasta_base + 'Biemna_sp_UH_2024/assembly/release/GCA_965654295.1/insdc/GCA_965654295.1.fa'
            assertAll(
                { assert workflow.success },
                { assert workflow.out.cram.size() == 1 },
