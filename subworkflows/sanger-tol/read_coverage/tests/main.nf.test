nextflow_workflow {

    name "Test Subworkflow READ_COVERAGE"
    script "../main.nf"
    workflow "READ_COVERAGE"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_sangertol"
    tag "subworkflows/read_coverage"
    tag "minimap2/align"
    tag "subworkflows/../../modules/sanger-tol/minimap2/align"
    tag "subworkflows/../../modules/nf-core/find/concatenate"
    tag "subworkflows/../../modules/nf-core/bedtools/sort"
    tag "subworkflows/../../modules/nf-core/bedtools/genomecov"
    tag "subworkflows/../../modules/nf-core/ucsc/bedgraphtobigwig"

    setup {
            nfcoreInitialise("${launchDir}/library/")
            nfcoreInstall(
                "${launchDir}/library/",
                [
                    "bedtools/sort",
                    "find/concatenate",
                    "bedtools/genomecov",
                    "ucsc/bedgraphtobigwig"
                ]
            )
            nfcoreLink("${launchDir}/library/", "${baseDir}/modules/")
    }

    test("Escherichia - ont read fastq") {

        when {
            params {
                minimap2_align_args = "-x map-ont"
                bedtools_genomecov_args = "-bg"
            }
            workflow {
                """
                input[0] = Channel.of(
                    [
                        [ id:'test', readtype:'ont' ],
                        [
                            file(params.modules_testdata_base_path + 'Escherichia_coli/genomic_data/ont/ont.fastq.gz', checkIfExists: true),
                            file(params.modules_testdata_base_path + 'Escherichia_coli/genomic_data/ont/ont.fastq.gz', checkIfExists: true)
                        ]
                    ]
                )
                input[1] = Channel.of(
                    [
                        [ id:'test' ],
                        file(params.modules_testdata_base_path + 'Escherichia_coli/reference/genome.fasta.gz', checkIfExists: true)
                    ]
                )
                input[2] = Channel.of(
                    file(params.modules_testdata_base_path + 'Escherichia_coli/reference/genome.chrom.sizes', checkIfExists: true)
                )
                input[3] = true
                """
            }
        }

         then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.bigwig.collect { file(it.get(1)).getName() },
                    workflow.out.bedgraph.collect { file(it.get(1)).getName() }
                ).match()
                }
            )
        }

        cleanup {
            if (this.metaClass.respondsTo(this, "nfcoreUnlink", String, String)) {
                nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
            }
        }
    }

    test("Escherichia - illumina read fastq optional bedgraph") {

        when {
            params {
                minimap2_align_args = "-x sr"
                bedtools_genomecov_args = "-bg"
            }
            workflow {
                """
                input[0] = Channel.of(
                    [
                        [ id:'test', readtype:'ont' ],
                        [
                            file(params.modules_testdata_base_path + 'Escherichia_coli/genomic_data/illumina/illumina.fastq.gz', checkIfExists: true),
                            file(params.modules_testdata_base_path + 'Escherichia_coli/genomic_data/illumina/illumina.fastq.gz', checkIfExists: true)
                        ]
                    ]
                )
                input[1] = Channel.of(
                    [
                        [ id:'test' ],
                        file(params.modules_testdata_base_path + 'Escherichia_coli/reference/genome.fasta.gz', checkIfExists: true)
                    ]
                )
                input[2] = Channel.of(
                    file(params.modules_testdata_base_path + 'Escherichia_coli/reference/genome.chrom.sizes', checkIfExists: true)
                )
                input[3] = false
                """
            }
        }

         then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.bigwig.collect { file(it.get(1)).getName() }
                ).match()
                }
            )
        }

        cleanup {
            if (this.metaClass.respondsTo(this, "nfcoreUnlink", String, String)) {
                nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
            }
        }
    }

    test("baUndUnlc1 - hifi read fasta") {

        when {
            params {
                minimap2_align_args = "-x map-hifi"
                bedtools_genomecov_args = "-bg"
            }
            workflow {
                """
                input[0] = Channel.of(
                    [
                        [ id:'test', readtype:'hifi' ],
                        [
                            file(params.modules_testdata_base_path + 'Undibacterium_unclassified/genomic_data/baUndUnlc1/pacbio/fasta/HiFi.reads.fasta', checkIfExists: true),
                            file(params.modules_testdata_base_path + 'Undibacterium_unclassified/genomic_data/baUndUnlc1/pacbio/fasta/HiFi.reads.fasta', checkIfExists: true)
                        ]
                    ]
                )
                input[1] = Channel.of(
                    [
                        [ id:'test' ],
                        file(params.modules_testdata_base_path + 'Undibacterium_unclassified/assembly/draft/baUndUnlc1.hic.hap2.p_ctg.fa.gz', checkIfExists: true)
                    ]
                )
                input[2] = Channel.of(
                    file(params.modules_testdata_base_path + 'Undibacterium_unclassified/assembly/draft/baUndUnlc1.hic.hap2.p_ctg.genome', checkIfExists: true)
                )
                input[3] = true
                """
            }
        }

         then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.bigwig.collect { file(it.get(1)).getName() },
                    workflow.out.bedgraph.collect { file(it.get(1)).getName() }
                ).match()
                }
            )
        }

        cleanup {
            if (this.metaClass.respondsTo(this, "nfcoreUnlink", String, String)) {
                nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
            }
        }
    }
}
