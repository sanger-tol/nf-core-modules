nextflow_workflow {

    name "Test Subworkflow TELO_FINDER"
    script "../main.nf"
    config "./nextflow.config"
    workflow "TELO_FINDER"

    tag "subworkflows"
    tag "subworkflows_sangertol"
    tag "subworkflows/telo_finder"
    tag "telomere/findtelomere"
    tag "tabix/bgziptabix"
    tag "subworkflows/../../modules/nf-core/tabix/bgziptabix"

    setup {
            nfcoreInitialise("${launchDir}/library/")
            nfcoreInstall(
                "${launchDir}/library/",
                [
                    "tabix/bgziptabix",
                ]
            )
            nfcoreLink("${launchDir}/library/", "${baseDir}/modules/")
    }

    test("Cloeon_Dipeterum - no split") {
        when {
            params {
                telomerewindow_args = "0.99 0.05"
                bgzip_args          = ''
            }
            workflow {
                """
                // Using Channel.fromList ensures the 'combine' operator works correctly
                input[0] = Channel.fromList([
                    [
                        [ id: "Cloeon_Dipeterum" ],
                        file(params.modules_testdata_base_path + 'Cloeon_dipterum/assembly/release/ieCloDipt1.1/insdc/GCA_949628265.1.fasta.gz', checkIfExists: true)
                    ]
                ])
            
                input[1] = Channel.fromList([
                    [
                        [ id: "Cloeon_Dipeterum" ],
                        "CCTAA"
                    ]
                ])
            
                input[2] = false
                input[3] = false
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
            )
        }

        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }

    test("Cloeon_Dipeterum - split - zipbed") {
        when {
            params {
                telomerewindow_args = "0.99 0.05"
                bgzip_args          = "--csi"
            }
            workflow {
                """
                // Using Channel.fromList ensures the 'combine' operator works correctly
                input[0] = Channel.fromList([
                    [
                        [ id: "Cloeon_Dipeterum" ],
                        file(params.modules_testdata_base_path + 'Cloeon_dipterum/assembly/release/ieCloDipt1.1/insdc/GCA_949628265.1.fasta.gz', checkIfExists: true)
                    ]
                ])
            
                input[1] = Channel.fromList([
                    [
                        [ id: "Cloeon_Dipeterum" ],
                        "CCTAA"
                    ]
                ])
            
                input[2] = true
                input[3] = true
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
            )
        }

        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }

    
}
